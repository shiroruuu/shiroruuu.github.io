        const saveManualRecord = () => { if(!newRecord.amount || newRecord.amount <= 0) return alert('请填入有效金额'); const rec = { ...newRecord, id: editingRecord.value ? editingRecord.value.id : Date.now(), amountCNY: toCNY(newRecord.amount, newRecord.currency) }; if(!rec.date) rec.date = currentDate.value; if(editingRecord.value) { const idx = records.value.findIndex(x => x.id === rec.id); if(idx > -1) records.value[idx] = rec; } else { records.value.unshift(rec); } editingRecord.value = null; tab.value = 'records'; showToast('✅ 记账成功'); };
