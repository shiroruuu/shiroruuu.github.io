<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>智能多币种记账本 - 终极版</title>
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <style>
        :root {
            --bg: #0F1117; --surface: #1A1D27; --border: #2A2E3F;
            --text: #E8E9ED; --textSec: #8B8FA3; --accent: #6C5CE7;
            --income: #2ECC71; --expense: #E74C3C;
            --font-family: 'system-ui', -apple-system, sans-serif;
        }
        body {
            font-family: var(--font-family); background-color: var(--bg); color: var(--text);
            margin: 0; height: 100vh; overflow: hidden; transition: background-color 0.3s, color 0.3s;
        }
        .app-container {
            max-width: 480px; margin: 0 auto; height: 100vh; display: flex; flex-direction: column;
            background: var(--bg); position: relative; transition: background-color 0.3s;
        }
        
        .surface { background-color: rgba(var(--surface-rgb), 0.85); backdrop-filter: blur(10px); transition: background-color 0.3s; }
        .surface-solid { background-color: var(--surface); transition: background-color 0.3s; } 
        
        .text-main { color: var(--text); }
        .text-sec { color: var(--textSec); }
        .text-income { color: var(--income); }
        .text-expense { color: var(--expense); }
        
        .border-line { border-color: var(--border); transition: border-color 0.3s; }
        
        .accent-bg { background-color: var(--accent); color: #fff; }
        .accent-text { color: var(--accent); }
        
        input, select, textarea {
            background-color: rgba(0,0,0,0.15); border: 1px solid var(--border); color: var(--text);
            padding: 0.5rem 0.75rem; border-radius: 0.5rem; outline: none; width: 100%; box-sizing: border-box; font-family: inherit; transition: 0.2s;
        }
        button { cursor: pointer; border: none; outline: none; transition: 0.2s; font-family: inherit; }
        button:active { opacity: 0.7; }
        
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
        
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 50; display: flex; justify-content: center; align-items: flex-end; backdrop-filter: blur(2px); }
        .modal-content { background: var(--bg); width: 100%; max-width: 480px; max-height: 90vh; overflow-y: auto; border-radius: 1.25rem 1.25rem 0 0; padding: 1.5rem 1rem; box-sizing: border-box; }
        
        .cat-icon { width: 2.25rem; height: 2.25rem; border-radius: 0.625rem; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; background: rgba(128,128,128,0.1); overflow: hidden; }
        
        /* 默认聊天气泡基调 */
        .chat-bubble {
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            line-height: 1.5;
            transition: all 0.2s ease;
            -webkit-touch-callout: none;
            user-select: none;
        }
        .bubble-right { border-radius: 1.125rem 0.25rem 1.125rem 1.125rem; }
        .bubble-left { border-radius: 0.25rem 1.125rem 1.125rem 1.125rem; }
        
        /* 吐司提示动画 */
        .toast-enter-active, .toast-leave-active { transition: opacity 0.3s, transform 0.3s; }
        .toast-enter-from, .toast-leave-to { opacity: 0; transform: translate(-50%, -40%); }
    </style>
</head>
<body>
<div id="app">
    <div class="app-container" :style="cssVars">
        
        <!-- 全局 Toast 提示 -->
        <transition name="toast">
            <div v-if="toastMsg" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-black/80 text-white px-5 py-2.5 rounded-xl z-[999] text-sm backdrop-blur-md shadow-xl whitespace-nowrap">
                {{ toastMsg }}
            </div>
        </transition>

        <!-- 顶部导航条 -->
        <header class="flex justify-between items-center p-3 border-b border-line surface shadow-sm relative z-10" style="padding-top: calc(0.75rem + env(safe-area-inset-top, 0px));">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center accent-bg font-bold overflow-hidden shadow-sm" v-html="renderAnyIcon(settings.appLogo)"></div>
                <div>
                    <div class="text-sm font-bold text-main">{{ settings.appName }}</div>
                    <div class="text-[0.625rem] text-sec font-mono">{{ currentDateTime }}</div>
                </div>
            </div>
            <button @click="showConverter = true" class="text-xs bg-black/10 border border-line px-2 py-1 rounded flex flex-col items-end hover:bg-black/20">
                <span class="text-main font-mono">100 JPY ≈ {{ jpyToCnyRate }} CNY</span>
                <span class="text-[0.5625rem] text-sec">多币种换算 🔄</span>
            </button>
        </header>

        <!-- 主内容区 -->
        <main class="flex-1 overflow-hidden flex flex-col relative z-0">
            
            <!-- 聊天记账 -->
            <div v-show="tab === 'chat'" class="flex-1 flex flex-col h-full relative">
                <div v-if="settings.bgImage" class="absolute inset-0 bg-cover bg-center opacity-30 pointer-events-none z-0" :style="{ backgroundImage: `url(${settings.bgImage})` }"></div>
                
                <div class="flex-1 overflow-y-auto p-4 space-y-4 relative z-10" id="chat-box" @click="closeMsgMenu">
                    <!-- 聊天气泡列表 -->
                    <div v-for="(msg, i) in messages" :key="i" class="flex gap-2.5 w-full" :class="msg.role === 'user' ? 'flex-row-reverse' : 'flex-row'">
                        <div class="w-9 h-9 shrink-0 flex items-start justify-center">
                            <img v-if="i === 0 || messages[i-1].role !== msg.role" 
                                 :src="msg.role === 'user' ? settings.userAvatar : settings.botAvatar" 
                                 class="w-full h-full rounded-full object-cover border border-line shadow-sm bg-black/5">
                        </div>

                        <div class="max-w-[72%] flex flex-col" :class="msg.role === 'user' ? 'items-end' : 'items-start'">
                            <div class="px-3.5 py-2.5 text-[0.9375rem] break-words relative chat-bubble"
                                 :class="msg.role === 'user' ? 'bg-[var(--accent)] text-white bubble-right' : 'bg-[var(--surface)] border border-line text-main bubble-left'"
                                 @touchstart.passive="handleTouchStart($event, msg, i)"
                                 @touchend.passive="handleTouchEnd"
                                 @touchmove.passive="handleTouchMove"
                                 @contextmenu.prevent="openMsgMenu(msg, i)">
                                <div v-if="msg.img" class="mb-2"><img :src="msg.img" class="max-w-full rounded-md max-h-36 object-cover border border-white/10 shadow-sm"></div>
                                <div v-html="renderChatMsg(msg.content)" class="leading-relaxed whitespace-pre-wrap"></div>
                            </div>
                        </div>
                    </div>

                    <div v-if="loading" class="flex justify-start gap-2.5 w-full">
                        <div class="w-9 h-9 shrink-0"></div>
                        <div class="bg-[var(--surface)] border border-line chat-bubble bubble-left px-4 py-2 text-xs text-sec flex items-center gap-2">
                            <span class="animate-pulse">思考中...</span>
                        </div>
                    </div>
                    
                    <!-- 确认记录卡片 -->
                    <div v-if="pendingRecords.length > 0" class="surface-solid border border-[var(--accent)] rounded-2xl p-4 mx-2 my-2 shadow-xl">
                        <div class="text-xs text-sec mb-3 font-bold">待确认账单：</div>
                        <div v-for="(r, idx) in pendingRecords" :key="idx" class="flex justify-between items-center py-1.5 border-b border-line border-dashed last:border-0">
                            <span class="text-sm text-main flex items-center gap-1.5 font-bold">
                                <span class="w-6 h-6 flex items-center justify-center text-lg" v-html="renderAnyIcon(getCatIcon(r.category))"></span>
                                {{ getCatName(r.category) }} <span class="text-xs text-sec ml-1 font-normal">{{ r.note }}</span>
                            </span>
                            <div class="text-right">
                                <div class="text-[0.9375rem] font-bold font-mono" :class="r.type === 'income' ? 'text-income' : 'text-expense'">
                                    {{ r.type === 'income' ? '+' : '-' }}{{ r.amount }} {{ r.currency }}
                                </div>
                                <div v-if="r.currency !== 'CNY'" class="text-[0.625rem] text-sec font-mono">≈ ¥{{ r.amountCNY.toFixed(2) }}</div>
                            </div>
                        </div>
                        <div class="flex gap-3 mt-4">
                            <button @click="confirmRecords" class="flex-1 accent-bg py-2.5 rounded-xl text-sm font-bold shadow-md hover:brightness-110">确认记录</button>
                            <button @click="pendingRecords =[]" class="flex-1 bg-black/10 text-main py-2.5 rounded-xl text-sm border border-line hover:bg-black/20">取消</button>
                        </div>
                    </div>
                </div>
                
                <!-- 底部操作区 (加高内边距) -->
                <div class="p-4 border-t border-line surface relative z-10 flex flex-col gap-3.5">
                    <div class="flex gap-2 px-1">
                        <input type="file" ref="imgUpload" accept="image/*" @change="handleImageUpload" class="hidden">
                        <button @click="$refs.imgUpload.click()" class="text-xs text-sec hover:text-main px-3 py-1.5 rounded-lg bg-black/10 border border-line flex items-center gap-1 font-bold">
                            <span class="w-4 h-4 flex items-center justify-center" v-html="renderAnyIcon(settings.uiIcons.actionImg)"></span> 截图
                        </button>
                        <button @click="showStickers = !showStickers" class="text-xs text-sec hover:text-main px-3 py-1.5 rounded-lg bg-black/10 border border-line flex items-center gap-1 font-bold">
                            <span class="w-4 h-4 flex items-center justify-center" v-html="renderAnyIcon(settings.uiIcons.actionSticker)"></span> 表情
                        </button>
                    </div>
                    
                    <div v-if="showStickers" class="flex gap-2 overflow-x-auto p-2.5 bg-black/20 rounded-xl border border-line shadow-inner">
                        <div v-for="s in settings.stickers" :key="s.name" @click="sendSticker(s)" class="shrink-0 cursor-pointer hover:scale-105 transition-transform bg-white/5 p-1 rounded-lg">
                            <img :src="s.url" :title="s.name" class="w-12 h-12 object-contain rounded">
                        </div>
                    </div>

                    <div v-if="selectedImg" class="flex items-center gap-2 p-2 bg-black/20 rounded-lg border border-line">
                        <span class="text-xs text-sec ml-1">已选截图</span><button @click="selectedImg = null" class="text-expense text-xs ml-auto font-bold bg-white/5 px-2 py-1 rounded">✖ 取消</button>
                    </div>

                    <!-- 全新设计的按键群发栏 (高度由 h-12 提升到 h-14，按钮增大至 w-12 h-12) -->
                    <div class="relative flex gap-2.5 h-14 items-center">
                        
                        <!-- 1. 重新生成按钮 (左侧) -->
                        <button @click="regenerateLast" :disabled="loading" class="w-12 h-12 shrink-0 rounded-full accent-bg flex items-center justify-center disabled:opacity-50 shadow-md active:scale-95 transition-transform text-white" title="重新生成回复">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                        </button>

                        <div class="flex-1 h-full relative flex items-center min-w-0">
                            <!-- 表情联想下拉框 -->
                            <div v-if="suggestedStickers.length > 0" class="absolute bottom-full left-0 mb-3 surface border border-line rounded-2xl p-2.5 flex gap-3 overflow-x-auto max-w-full shadow-2xl z-50">
                                <div v-for="s in suggestedStickers" :key="s.name" @click="sendSticker(s)" class="shrink-0 cursor-pointer hover:scale-110 transition-transform flex flex-col items-center gap-1 bg-white/5 p-1.5 rounded-xl">
                                    <img :src="s.url" class="w-12 h-12 object-contain rounded"><span class="text-[0.5625rem] text-sec font-bold">{{ s.name }}</span>
                                </div>
                            </div>
                            <!-- 输入框 (增加文字大小和内边距) -->
                            <input v-model="inputText" @keydown.enter="pushUserMessage" :placeholder="settings.chatPlaceholder" class="w-full h-full bg-black/10 border border-line rounded-full px-5 text-base outline-none text-main focus:border-[var(--accent)] transition-colors placeholder:text-sec shadow-inner min-w-0">
                        </div>

                        <!-- 2. 小飞机发出消息按钮 (右侧 1) -->
                        <button @click="pushUserMessage" :disabled="loading" class="w-12 h-12 shrink-0 rounded-full accent-bg flex items-center justify-center disabled:opacity-50 shadow-md active:scale-95 transition-transform text-white" title="仅发送消息">
                            <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 ml-0.5"><path d="M3.478 2.404a.75.75 0 00-.926.941l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.404z"></path></svg>
                        </button>

                        <!-- 3. AI生成/强制回复按钮 (右侧 2) -->
                        <button @click="generateReply" :disabled="loading" class="w-12 h-12 shrink-0 rounded-full accent-bg flex items-center justify-center disabled:opacity-50 shadow-md active:scale-95 transition-transform text-white" title="生成 AI 回复">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 手动记账页面 -->
            <div v-show="tab === 'add'" class="flex-1 overflow-y-auto p-4 relative z-10 flex flex-col">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="font-bold text-lg">{{ editingRecord ? '编辑历史记录' : '手动记账' }}</h2>
                    <button v-if="editingRecord" @click="cancelEdit" class="text-xs text-sec border border-line px-2 py-1 rounded">取消编辑</button>
                </div>
                <div class="flex gap-2 mb-4">
                    <button @click="newRecord.type = 'expense'" class="flex-1 py-3 text-sm rounded-lg border border-line font-bold transition-colors" :class="newRecord.type==='expense'?'!border-[var(--expense)] text-expense bg-red-500/10 shadow-sm':''">支出</button>
                    <button @click="newRecord.type = 'income'" class="flex-1 py-3 text-sm rounded-lg border border-line font-bold transition-colors" :class="newRecord.type==='income'?'!border-[var(--income)] text-income bg-green-500/10 shadow-sm':''">收入</button>
                </div>
                <div class="grid grid-cols-5 gap-2 mb-6 p-2 bg-black/5 rounded-xl max-h-48 overflow-y-auto border border-line shadow-inner">
                    <button v-for="cat in (newRecord.type === 'expense' ? settings.expenseCats : settings.incomeCats)" :key="cat.id" 
                            @click="newRecord.category = cat.id"
                            class="flex flex-col items-center justify-center gap-1.5 p-2 rounded-xl border transition-all" :class="newRecord.category === cat.id ? 'border-[var(--accent)] accent-bg shadow-md scale-105' : 'border-transparent hover:bg-white/5'">
                        <div class="w-8 h-8 flex items-center justify-center text-2xl" v-html="renderAnyIcon(cat.icon)"></div>
                        <div class="text-[0.5625rem] truncate w-full text-center" :class="newRecord.category === cat.id ? 'font-bold' : ''">{{ cat.name }}</div>
                    </button>
                </div>
                
                <!-- 手动记账输入框加高为 h-14 -->
                <div class="flex gap-2 mb-4 h-14 items-center">
                    <input type="number" v-model.number="newRecord.amount" placeholder="金额数字" class="flex-1 h-full bg-black/10 border border-line rounded-xl px-4 text-base font-bold font-mono outline-none text-main focus:border-[var(--accent)] transition-colors">
                    <select v-model="newRecord.currency" class="w-24 h-full bg-black/10 border border-line rounded-xl px-3 text-sm font-bold text-center outline-none focus:border-[var(--accent)] transition-colors">
                        <option value="CNY">CNY</option><option value="JPY">JPY</option><option value="USD">USD</option>
                        <option value="EUR">EUR</option><option value="GBP">GBP</option><option value="KRW">KRW</option>
                        <option value="HKD">HKD</option><option value="TWD">TWD</option>
                    </select>
                </div>
                <div class="flex gap-2 mb-6 h-14 items-center">
                    <input type="date" v-model="newRecord.date" class="w-36 h-full bg-black/10 border border-line rounded-xl px-4 text-sm outline-none focus:border-[var(--accent)] transition-colors">
                    <input type="text" v-model="newRecord.note" placeholder="填写备注信息..." class="flex-1 h-full bg-black/10 border border-line rounded-xl px-4 text-sm outline-none focus:border-[var(--accent)] transition-colors">
                </div>
                <button @click="saveManualRecord" class="w-full accent-bg py-4 rounded-xl font-bold text-base shadow-lg mt-auto active:scale-[0.98]">
                    {{ editingRecord ? '保存修改' : '确认记账' }}
                </button>
            </div>

            <!-- 记录明细 -->
            <div v-show="tab === 'records'" class="flex-1 overflow-y-auto p-4 relative z-10">
                <div class="flex justify-between items-center mb-4 border-b border-line pb-3">
                    <input type="month" v-model="filterMonth" class="bg-transparent border-none text-main text-base font-bold w-32 p-0 focus:ring-0 cursor-pointer">
                    <div class="text-xs text-sec font-bold">本月结余: <span class="text-[0.9375rem]" :class="monthBalance >= 0 ? 'text-income' : 'text-expense'">¥{{ monthBalance.toFixed(2) }}</span></div>
                </div>
                <div v-if="filteredRecords.length === 0" class="text-center text-sec mt-10 text-sm">暂无记录</div>
                
                <div v-for="(group, date) in groupedRecords" :key="date" class="mb-5">
                    <div class="text-xs text-sec mb-2.5 font-mono font-bold">{{ date }}</div>
                    <div class="space-y-2.5">
                        <div v-for="r in group" :key="r.id" @click="editRecord(r)" class="surface border border-line p-3.5 rounded-2xl flex items-center gap-3 cursor-pointer hover:border-[var(--accent)] transition-all shadow-sm">
                            <div class="cat-icon bg-black/5" v-html="renderAnyIcon(getCatIcon(r.category))"></div>
                            <div class="flex-1 min-w-0">
                                <div class="text-[0.9375rem] text-main font-bold truncate">{{ getCatName(r.category) }}</div>
                                <div v-if="r.note" class="text-[0.6875rem] text-sec truncate mt-0.5">{{ r.note }}</div>
                            </div>
                            <div class="text-right">
                                <div class="text-[0.9375rem] font-bold font-mono" :class="r.type === 'income' ? 'text-income' : 'text-expense'">
                                    {{ r.type === 'income' ? '+' : '-' }}{{ r.amount }} <span class="text-[0.625rem]">{{ r.currency }}</span>
                                </div>
                                <div v-if="r.currency !== 'CNY'" class="text-[0.6875rem] text-sec font-mono mt-0.5">≈ ¥{{ r.amountCNY.toFixed(2) }}</div>
                            </div>
                            <button @click.stop="deleteRecord(r.id)" class="text-expense px-2 py-1.5 bg-red-500/10 rounded-lg ml-2 font-bold text-xs hover:bg-red-500/20">✕</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 统计分析 -->
            <div v-show="tab === 'stats'" class="flex-1 flex flex-col p-4 relative z-10 h-full">
                <div class="flex justify-between items-center surface border border-line p-3 rounded-2xl mb-4 shrink-0 shadow-sm">
                    <button @click="changeStatPeriod('prev')" class="text-sec hover:text-main px-3 py-1 bg-black/5 rounded font-bold">◀</button>
                    <div class="text-center">
                        <div class="text-sm font-bold text-main">{{ statLabel }}</div>
                        <div class="text-[0.625rem] text-sec flex gap-3 justify-center mt-1.5">
                            <button :class="{ 'accent-text font-bold': statPeriod === 'day' }" @click="statPeriod = 'day'; selectedStatCat = null">日</button>
                            <button :class="{ 'accent-text font-bold': statPeriod === 'week' }" @click="statPeriod = 'week'; selectedStatCat = null">周</button>
                            <button :class="{ 'accent-text font-bold': statPeriod === 'month' }" @click="statPeriod = 'month'; selectedStatCat = null">月</button>
                            <button :class="{ 'accent-text font-bold': statPeriod === 'halfYear' }" @click="statPeriod = 'halfYear'; selectedStatCat = null">半年</button>
                        </div>
                    </div>
                    <button @click="changeStatPeriod('next')" class="text-sec hover:text-main px-3 py-1 bg-black/5 rounded font-bold">▶</button>
                </div>

                <div class="surface border border-line p-4 rounded-2xl flex-1 flex flex-col items-center justify-center relative shrink-0 min-h-[220px] shadow-inner">
                    <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                        <template v-if="selectedStatCat">
                            <div class="text-xs text-sec font-bold">{{ selectedStatCat.name }}</div>
                            <div class="text-xl font-bold text-expense mt-0.5">¥{{ selectedStatCat.amount.toFixed(2) }}</div>
                            <div class="text-[0.6875rem] text-sec mt-1">{{ selectedStatCat.percent }}%</div>
                        </template>
                        <template v-else>
                            <div class="text-xs text-sec font-bold">总支出</div>
                            <div class="text-xl font-bold text-expense mt-0.5 font-mono">¥{{ statTotalExpense.toFixed(2) }}</div>
                        </template>
                    </div>
                    <div v-if="statDataList.length === 0" class="absolute inset-0 flex items-center justify-center bg-black/40 backdrop-blur-md rounded-2xl z-10 text-sec text-sm font-bold">当前时段无支出</div>
                    <div class="w-full h-full relative z-0 max-w-[200px]"><canvas id="statDoughnutChart"></canvas></div>
                </div>

                <div class="mt-4 flex-1 overflow-y-auto space-y-2.5 shrink-0 max-h-[40%]">
                    <div v-for="item in statDataList" :key="item.id" @click="selectedStatCat = item" 
                         class="flex justify-between items-center surface border p-3 rounded-xl cursor-pointer transition-colors shadow-sm"
                         :class="selectedStatCat && selectedStatCat.id === item.id ? 'border-[var(--accent)] bg-white/5' : 'border-line'">
                        <div class="flex items-center gap-2.5">
                            <span class="w-9 h-9 rounded-lg flex items-center justify-center bg-black/5" v-html="renderAnyIcon(item.icon)"></span>
                            <span class="text-[0.9375rem] text-main font-bold">{{ item.name }}</span>
                        </div>
