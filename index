        const currentBalance = computed(() => totalIncome.value - totalExpense.value + (settings.balanceOffset || 0));
        
        const setBalance = () => { if (inputBalance.value === '' || isNaN(inputBalance.value)) return alert("请输入有效金额"); settings.balanceOffset = inputBalance.value - (totalIncome.value - totalExpense.value); saveData(); inputBalance.value = ''; showToast("✅ 余额已校准！"); };

        const catEditType = ref('expense');
        const currentEditCats = computed(() => catEditType.value === 'expense' ? settings.expenseCats : settings.incomeCats);
        const suggestedStickers = computed(() => !inputText.value.trim() ?[] : settings.stickers.filter(s => s.name.includes(inputText.value.trim())));

        const loadData = () => {
            const data = localStorage.getItem('vApp_data');
            if (data) {
                const p = JSON.parse(data);
                if (p.settings && p.settings.theme && !p.settings.darkTheme) p.settings.darkTheme = { ...DEFAULT_SETTINGS.darkTheme, ...p.settings.theme };
                Object.keys(DEFAULT_SETTINGS).forEach(k => {
                    if(typeof p.settings[k] === 'object' && !Array.isArray(p.settings[k])) { settings[k] = { ...DEFAULT_SETTINGS[k], ...(p.settings[k]||{}) }; } 
                    else if (p.settings[k] !== undefined) { settings[k] = p.settings[k]; }
                });
                records.value = p.records ||[];
            }
        };
        const saveData = () => localStorage.setItem('vApp_data', JSON.stringify({ settings, records: records.value }));
        watch([settings, records], saveData, { deep: true });

        const fetchRates = async () => { try { const res = await fetch('https://open.er-api.com/v6/latest/CNY'); const data = await res.json(); rates.value = data.rates; ratesDate.value = new Date(data.time_last_update_unix * 1000).toLocaleDateString(); } catch(e) {} };
        const calcConvert = (targetCur) => ((convertAmount.value / (rates.value[convertBase.value] || 1)) * (rates.value[targetCur] || 1));
        const toCNY = (amount, cur) => cur === 'CNY' ? amount : (rates.value[cur] ? (amount / rates.value[cur]) : amount);
        const getCatName = (id) => ([...settings.expenseCats, ...settings.incomeCats].find(c => c.id === id)?.name || '其他');
        const getCatIcon = (id) => ([...settings.expenseCats, ...settings.incomeCats].find(c => c.id === id)?.icon || '❓');
        
        const renderAnyIcon = (str) => { if(!str) return ''; if(str.startsWith('http') || str.startsWith('data:image')) return `<img src="${str}" class="w-full h-full object-contain">`; return str; };
        const renderChatMsg = (text) => {
            if(!text) return ''; let html = text.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            html = html.replace(/\[sticker:([^\]]+)\]/g, (match, name) => {
                const s = settings.stickers.find(x => x.name === name);
                if (s) return `<img src="${s.url}" alt="${name}" class="inline-block h-[4.5rem] w-[4.5rem] object-contain align-middle mx-1.5 my-1 drop-shadow-sm">`; return match;
            });
            return html;
        };

        const handleFontUpload = (e) => { const f = e.target.files[0]; if(!f) return; const r = new FileReader(); r.onload = () => { settings.fontDataUrl = r.result; saveData(); showToast('✅ 字体已应用'); }; r.readAsDataURL(f); };

        const statRange = computed(() => {
            const d = new Date(statAnchor.value); let start, end;
            if(statPeriod.value === 'day') { start = new Date(d); end = new Date(d); }
            else if(statPeriod.value === 'week') { const day = d.getDay() || 7; start = new Date(d); start.setDate(start.getDate() - day + 1); end = new Date(d); end.setDate(end.getDate() - day + 7); }
            else if(statPeriod.value === 'month') { start = new Date(d.getFullYear(), d.getMonth(), 1); end = new Date(d.getFullYear(), d.getMonth() + 1, 0); }
            else if(statPeriod.value === 'halfYear') { const isH1 = d.getMonth() < 6; start = new Date(d.getFullYear(), isH1 ? 0 : 6, 1); end = new Date(d.getFullYear(), isH1 ? 6 : 12, 0); }
            return { start: `${start.getFullYear()}-${pad(start.getMonth()+1)}-${pad(start.getDate())}`, end: `${end.getFullYear()}-${pad(end.getMonth()+1)}-${pad(end.getDate())}` };
        });

        const statLabel = computed(() => { const { start, end } = statRange.value; const today = currentDate.value; if(statPeriod.value === 'day') return start === today ? '今日' : start; if (statPeriod.value === 'month') return `${start.slice(0, 4)}年${parseInt(start.slice(5, 7))}月`; return `${start} ~ ${end}`; });
        const changeStatPeriod = (dir) => { const d = new Date(statAnchor.value); const sign = dir === 'prev' ? -1 : 1; if(statPeriod.value === 'day') d.setDate(d.getDate() + sign); else if(statPeriod.value === 'week') d.setDate(d.getDate() + sign * 7); else if(statPeriod.value === 'month') d.setMonth(d.getMonth() + sign); else if(statPeriod.value === 'halfYear') d.setMonth(d.getMonth() + sign * 6); statAnchor.value = d; selectedStatCat.value = null; };
        const statDataList = computed(() => { const { start, end } = statRange.value; const recs = records.value.filter(r => r.date >= start && r.date <= end && r.type === 'expense'); const total = recs.reduce((sum, r) => sum + (r.amountCNY || r.amount), 0); const map = {}; recs.forEach(r => map[r.category] = (map[r.category] || 0) + (r.amountCNY || r.amount)); return Object.keys(map).map(catId => ({ id: catId, name: getCatName(catId), icon: getCatIcon(catId), amount: map[catId], percent: total > 0 ? ((map[catId]/total)*100).toFixed(1) : '0.0' })).sort((a,b) => b.amount - a.amount); });
        const statTotalExpense = computed(() => statDataList.value.reduce((s, x) => s + x.amount, 0));

