        const groupedRecords = computed(() => { const map = {}; filteredRecords.value.forEach(r => { if(!map[r.date]) map[r.date] =[]; map[r.date].push(r); }); return map; });
        const monthBalance = computed(() => filteredRecords.value.reduce((acc, r) => acc + (r.type === 'income' ? (r.amountCNY || r.amount) : -(r.amountCNY || r.amount)), 0));
