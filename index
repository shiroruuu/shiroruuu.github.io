            await fetchAiResponse();
        };

        // 按下重新生成按钮
        const regenerateLast = async () => {
            if(loading.value) return;
            let lastIdx = messages.value.map(m => m.role).lastIndexOf('assistant');
            if(lastIdx !== -1) {
                messages.value.splice(lastIdx, 1);
            }
            await fetchAiResponse();
        };

        const confirmRecords = () => { pendingRecords.value.forEach(r => records.value.unshift({ ...r, id: Date.now() + Math.random() })); messages.value.push({ role: 'assistant', content: `✅ 已经帮你记好 ${pendingRecords.value.length} 笔啦！` }); pendingRecords.value =[]; showToast("✅ 记录成功"); nextTick(()=> { const box = document.getElementById('chat-box'); if(box) box.scrollTop = box.scrollHeight; }); };

        const handleBgUpload = (e) => { const f = e.target.files[0]; if(!f) return; const r = new FileReader(); r.onload = () => { settings.bgImage = r.result; saveData(); }; r.readAsDataURL(f); };
        const fetchModels = async () => { if(!settings.api.key) return alert("请先填写API Key"); try { const res = await fetch(`${settings.api.baseUrl.replace(/\/+$/, '')}/v1/models`, { headers: { 'Authorization': `Bearer ${settings.api.key}` } }); const data = await res.json(); if(data.data) { settings.availableModels = data.data.map(m => m.id); showToast("获取成功"); } } catch(e) { alert("获取失败: " + e.message); } };
        const importStickers = () => { const lines = stickerImportText.value.split('\n'); const arr =[]; lines.forEach(l => { const[n, u] = l.split(','); if(n && u) arr.push({ name: n.trim(), url: u.trim() }); }); if(arr.length) { settings.stickers =[...settings.stickers, ...arr]; stickerImportText.value = ''; saveData(); showToast("✅ 导入成功"); } };
        const requestNotificationPermission = async () => { if(settings.reminder.enabled && "Notification" in window && Notification.permission !== "granted") await Notification.requestPermission(); };
        const checkReminder = () => { if(!settings.reminder.enabled) return; const timeStr = `${pad(now.value.getHours())}:${pad(now.value.getMinutes())}`; const todayStr = currentDate.value; if(timeStr === settings.reminder.time && settings.reminder.lastTrigger !== todayStr) { settings.reminder.lastTrigger = todayStr; saveData(); if(Notification.permission === "granted") new Notification(settings.appName + " 提醒", { body: settings.reminder.text, icon: '💰' }); } };

        const exportData = () => { const blob = new Blob([JSON.stringify({ settings, records: records.value })], { type: 'application/json' }); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = `数据_${currentDate.value}.json`; a.click(); URL.revokeObjectURL(url); };
        const importData = () => document.querySelector('input[accept=".json"]').click();
        const handleImportFile = (e) => { const f = e.target.files[0]; if(!f) return; const r = new FileReader(); r.onload = (ev) => { try { const parsed = JSON.parse(ev.target.result); if(parsed.settings) Object.keys(DEFAULT_SETTINGS).forEach(k => { if (parsed.settings[k] !== undefined) settings[k] = parsed.settings[k]; }); if(parsed.records) records.value = parsed.records; saveData(); showToast("✅ 导入成功"); } catch(err) { alert("解析失败"); } }; r.readAsText(f); };
        const clearData = () => { if(confirm("确定清空吗？此操作不可逆！")) { localStorage.removeItem('vApp_data'); location.reload(); } };
        
        onMounted(() => { 
            loadData(); fetchRates(); setInterval(checkReminder, 60000); 
            const autoText = new URLSearchParams(window.location.search).get('text');
            if (autoText) { inputText.value = autoText; tab.value = 'chat'; setTimeout(() => { generateReply(); window.history.replaceState({}, document.title, window.location.pathname); }, 800); }
        });

        return {
            tab, navs, settings, records, loading, inputText, messages, pendingRecords, 
            editingRecord, showConverter, activeSettingPanel, filterMonth, toastMsg, showToast,
            msgMenu, handleTouchStart, handleTouchEnd, handleTouchMove, openMsgMenu, closeMsgMenu, copyMsgText, editMsgText, deleteMsgItem,
            rates, ratesDate, convertAmount, convertBase, newRecord, currentDateTime, currentDate, jpyToCnyRate,
            filteredRecords, groupedRecords, monthBalance, settingMenus, catEditType, currentEditCats,
            selectedImg, showStickers, stickerImportText, suggestedStickers,
            statPeriod, statAnchor, selectedStatCat, statLabel, statDataList, statTotalExpense,
            currentBalance, inputBalance, toggleThemeMode,
            cssVars, getCatName, getCatIcon, renderAnyIcon, renderChatMsg,
            saveData, fetchModels, importStickers, requestNotificationPermission, calcConvert,
            sendSticker, handleImageUpload, confirmRecords, toCNY, changeStatPeriod, handleFontUpload,
            pushUserMessage, generateReply, regenerateLast, /* 导出了最新拆分的三种控制能力 */
            saveManualRecord, editRecord, cancelEdit, deleteRecord, handleBgUpload, setBalance,
            exportData, importData, handleImportFile, clearData
        };
    }
}).mount('#app');
</script>
</body>
</html>
