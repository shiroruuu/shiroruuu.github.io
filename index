        // 触发 AI 的核心请求逻辑
        const fetchAiResponse = async () => {
            loading.value = true; pendingRecords.value =[]; 
            nextTick(()=> { const box = document.getElementById('chat-box'); if(box) box.scrollTop = box.scrollHeight; });

            try {
                const ratesStr = Object.entries(rates.value).filter(([k])=>k!=='CNY').map(([k,v]) => `1${k}=${(1/v).toFixed(4)}CNY`).join(', ');
                const expStr = settings.expenseCats.map(c => `${c.id}(${c.name})`).join(', ');
