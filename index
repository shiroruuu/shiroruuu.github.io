支持支出ID：${expStr} | 收入ID：${incStr}
汇率参考：${ratesStr}
以你的【性格人设】回复，并在最后输出纯净版JSON:
\`\`\`json
{"records":[{"type":"expense","category":"food","amount":1000,"currency":"JPY","amountCNY":50.12,"date":"${currentDate.value}","note":"午饭"}]}
\`\`\`
`;
                const aiMsgs =[ { role: 'system', content: sysPrompt } ];
                // 取最近5条记录送给AI，包含刚发出去的多条连续消息
                const hist = messages.value.slice(-5).map(m => ({ role: m.role, content: m.img ?[{type:'text',text:m.content||'图片'},{type:'image_url',image_url:{url:m.img}}] : m.content }));
                aiMsgs.push(...hist);

                if (!settings.api.key) throw new Error("请先在设置中配置 API Key");
                const res = await fetch(`${settings.api.baseUrl.replace(/\/+$/, '')}/v1/chat/completions`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${settings.api.key}` },
                    body: JSON.stringify({ model: settings.api.model, messages: aiMsgs, temperature: 0.7 })
                });
                if(!res.ok) throw new Error((await res.json()).error?.message || '请求失败');
                
                const aiText = (await res.json()).choices[0].message.content;
                const displayMsg = aiText.replace(/```json[\s\S]*?```/g, "").trim();
                if(displayMsg) messages.value.push({ role: 'assistant', content: displayMsg });
                
                const jsonMatch = aiText.match(/```json\s*([\s\S]*?)\s*```/);
                if (jsonMatch) {
                    try {
                        const parsed = JSON.parse(jsonMatch[1]);
                        if(parsed.records?.length > 0) {
                            pendingRecords.value = parsed.records.map(r => ({
                                type: r.type || 'expense', category: r.category || 'food', amount: parseFloat(r.amount) || 0,
                                currency: r.currency || 'CNY', amountCNY: r.amountCNY || toCNY(parseFloat(r.amount)||0, r.currency||'CNY'),
                                date: r.date || currentDate.value, note: r.note || ''
                            }));
